{
  "name": "office-graph-operator-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 127.0.0.1",
    "router:build": "react-router build --config vite.react-router.config.ts",
    "router:deploy": "pnpm run router:build && node scripts/prepare-app-shell-assets.mjs",
    "router:routes": "react-router routes --config vite.react-router.config.ts",
    "router:typegen": "react-router typegen --config vite.react-router.config.ts",
    "relay:schema": "node scripts/graphql-schema.mjs --write",
    "relay": "pnpm run relay:schema && relay-compiler --noWatchman",
    "relay:check": "node scripts/graphql-schema.mjs --check && relay-compiler --noWatchman --validate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:import-boundaries": "vitest run src/ui/importBoundaries.test.ts app/routes/operator/architecture.test.ts",
    "verify:app-shell": "node scripts/verify-app-shell-assets.mjs",
    "verify": "pnpm run relay:check && pnpm run typecheck && pnpm run verify:import-boundaries && pnpm run test && pnpm run build && pnpm run router:deploy && pnpm run verify:app-shell"
  },
  "dependencies": {
    "@react-router/node": "8.1.0",
    "@stylexjs/stylex": "^0.19.0",
    "isbot": "^5",
    "react": "^19.0.0",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.0.0",
    "react-relay": "^21.0.1",
    "react-router": "8.1.0",
    "relay-runtime": "^21.0.1"
  },
  "devDependencies": {
    "@react-router/dev": "8.1.0",
    "@stylexjs/babel-plugin": "^0.19.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "babel-plugin-relay": "^21.0.1",
    "jsdom": "^26.0.0",
    "relay-compiler": "^21.0.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
